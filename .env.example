# ============================================================
# Commerce Analytics — Environment Configuration (PLACEHOLDERS)
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=commerce_analytics-speed-layer
KAFKA_TOPIC_CLICKSTREAM=commerce_analytics.clickstream
KAFKA_TOPIC_ORDERS=commerce_analytics.orders
KAFKA_TOPIC_INVENTORY=commerce_analytics.inventory
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
SCHEMA_REGISTRY_URL=http://localhost:8081

# --- MySQL (Product catalog) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=commerce_analytics_catalog
MYSQL_USER=commerce_analytics
MYSQL_PASSWORD=__PLACEHOLDER__

# --- PostgreSQL (Reporting) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=commerce_analytics_reports
POSTGRES_USER=commerce_analytics
POSTGRES_PASSWORD=__PLACEHOLDER__

# --- Redis (Sessions + RT dashboards) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
SESSION_TIMEOUT_MINUTES=30

# --- S3 ---
AWS_ACCESS_KEY_ID=__PLACEHOLDER__
AWS_SECRET_ACCESS_KEY=__PLACEHOLDER__
AWS_REGION=us-east-1
S3_BUCKET=commerce_analytics-warehouse
S3_RAW_PREFIX=raw/
S3_CURATED_PREFIX=curated/

# --- External APIs ---
PAYMENT_API_URL=https://api.payment.example.com
PAYMENT_API_KEY=__PLACEHOLDER__
SHIPPING_API_URL=https://api.shipping.example.com
SHIPPING_API_KEY=__PLACEHOLDER__

# --- Pipeline ---
BATCH_SIZE=1000
COMMIT_INTERVAL_MS=5000
BOT_VELOCITY_THRESHOLD=20
BOT_SCORE_BLOCK_THRESHOLD=0.7

# --- Metrics ---
PROMETHEUS_PORT=8001
